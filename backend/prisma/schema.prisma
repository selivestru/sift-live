generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid(2))
  username  String   @unique
  email     String   @unique
  password  String
  color     String   @default("#FF6B6B")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel           Channel?
  moderatedChannels ChannelModerator[]
  vipChannels       ChannelVip[]
  bannedChannels    ChannelBan[]
  followingChannels ChannelFollow[]
  messages          Message[]
  sessions          Session[]
}

model Category {
  id    String  @id @default(cuid(2))
  title String  @unique
  slug  String  @unique
  image String?

  channels Channel[]
}

model Channel {
  id        String   @id @default(cuid(2))
  title     String
  tags      String[] @default([])
  isLive    Boolean  @default(false)
  streamKey String   @unique

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  moderators ChannelModerator[]
  vips       ChannelVip[]
  bans       ChannelBan[]
  followers  ChannelFollow[]
  streams    Stream[]
  messages   Message[]

  @@index([categoryId])
}

model Stream {
  id        String    @id @default(cuid(2))
  title     String
  category  String?
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  videoUrl  String?

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  messages Message[]

  @@index([channelId])
}

model Message {
  id          String    @id @default(cuid(2))
  text        String
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  deletedById String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  streamId String?
  stream   Stream? @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([streamId])
  @@index([deletedAt])
}

model Session {
  id               String    @id @default(cuid(2))
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([userId])
  @@index([expiresAt])
}

model ChannelModerator {
  id           String   @id @default(cuid(2))
  channelId    String
  userId       String
  assignedAt   DateTime @default(now())
  assignedById String?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model ChannelVip {
  id         String   @id @default(cuid(2))
  channelId  String
  userId     String
  assignedAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model ChannelBan {
  id         String    @id @default(cuid(2))
  channelId  String
  userId     String
  bannedAt   DateTime  @default(now())
  expiresAt  DateTime?
  reason     String?
  bannedById String?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model ChannelFollow {
  id         String   @id @default(cuid(2))
  channelId  String
  followerId String
  createdAt  DateTime @default(now())

  channel  Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  follower User    @relation(fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([channelId, followerId])
  @@index([followerId])
}
